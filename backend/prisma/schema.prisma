generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Kine {
  id             Int       @id @default(autoincrement())
  uid            String    @unique
  email          String    @unique
  firstName      String
  lastName       String
  phone          String?
  rpps           String?   @unique
  birthDate      DateTime?
  adresseCabinet String?
  avatarPath     String? // Chemin GCS de l'avatar (ex: "avatars/123_photo.jpg")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // ========== INFOS PROFESSIONNELLES CONTRATS (optionnels, complétés au 1er contrat) ==========
  civilite         String? // "M." | "MME" — utilisé dans la rédaction des contrats
  birthPlace       String?
  departementOrdre String?
  numeroOrdinal    String?
  numeroUrssaf     String?
  adresseDomicile  String?
  // =============================================================================================

  // ========== TRAÇABILITÉ LÉGALE ==========
  acceptedCguAt                      DateTime? // Date/heure d'acceptation des CGU
  acceptedPolitiqueConfidentialiteAt DateTime? // Date/heure d'acceptation de la politique de confidentialité
  cguVersion                         String? // Version des CGU acceptées (ex: "2.0")
  politiqueConfidentialiteVersion    String? // Version de la politique de confidentialité acceptée
  signupIpAddress                    String? // IP lors de l'inscription (audit trail RGPD)
  // =========================================

  // ========== NOUVEAUX CHAMPS STRIPE ==========
  stripeCustomerId      String? // ID client Stripe
  subscriptionId        String? // ID abonnement Stripe actuel
  planType              PlanType? // Type de plan actuel
  subscriptionStatus    SubscriptionStatus? // Statut de l'abonnement
  subscriptionStartDate DateTime? // Date début abonnement
  subscriptionEndDate   DateTime? // Date fin abonnement
  trialEndDate          DateTime? // Date fin période d'essai (si applicable)
  // ===============================================

  // ========== PARRAINAGE ==========
  referralCode        String?    @unique // Code unique de parrainage (ex: "ABC123")
  referralsAsReferrer Referral[] @relation("ReferrerReferrals") // Parrainages effectués
  referralAsReferee   Referral?  @relation("RefereeReferral") // Parrainage reçu (unique)
  // ================================

  patients          Patient[]
  exercicesModeles  ExerciceModele[]
  exerciceTemplates ExerciceTemplate[]
  notifications     Notification[]

  // ========== NOUVELLES RELATIONS IA ==========
  chatIaBasique        ChatIaBasique[]
  chatIaBiblio         ChatIaBiblio[]
  chatIaClinique       ChatIaClinique[]
  chatIaAdministrative ChatIaAdministrative[]
  // =============================================

  // ========== RELATION RGPD ==========
  rgpdExports RgpdExport[]
  // ===================================

  // ========== RELATION TEMPLATES ADMIN ==========
  templatesSentHistory TemplateSentHistory[]
  // ==============================================

  // ========== RELATIONS CONTACTS & TEMPLATES PRIVÉS ==========
  contacts       Contact[]
  adminTemplates AdminTemplate[]
  // ===========================================================

  // ========== RELATION SUPPORT ==========
  supportTickets SupportTicket[]
  // ======================================

  // ========== RELATION BILANS ==========
  bilans         BilanKine[]
  bilanTemplates BilanTemplate[]
  // =====================================

  // ========== RELATION TRAÇABILITÉ LÉGALE ==========
  legalAcceptances LegalAcceptance[]
  // =================================================

  // ========== RELATIONS CONTRATS ==========
  contactsKine          ContactKine[]
  contractsInitiated    Contract[]          @relation("ContractInitiateur")
  contractsReceived     Contract[]          @relation("ContractDestinataire")
  contractSignatures    ContractSignature[]
  lastContractsViewedAt DateTime? // Pour badge "nouveau" sur contrats signés depuis dernière visite
  // ========================================
}

model Patient {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  birthDate DateTime
  phone     String
  email     String
  goals     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ========== SOFT DELETE ==========
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  // ================================

  // ========== CONSENTEMENTS COMMUNICATION ==========
  emailConsent    Boolean @default(false) // Accepte emails admin
  whatsappConsent Boolean @default(false) // Accepte WhatsApp admin
  // ================================================

  kineId Int
  kine   Kine @relation(fields: [kineId], references: [id])

  programmes           Programme[]
  chatSessions         ChatSession[]
  sessionValidations   SessionValidation[]
  notifications        Notification[]
  templatesSentHistory TemplateSentHistory[]
  bilans               BilanKine[]
}

model ExerciceModele {
  id          Int      @id @default(autoincrement())
  kine        Kine     @relation(fields: [kineId], references: [id])
  kineId      Int
  nom         String
  description String
  gifUrl      String? // DEPRECATED: Ancienne URL Firebase (pour migration)
  gifPath     String? // NOUVEAU: Chemin GCS (ex: "exercices/123_demo.gif") - HDS compliant
  tags        String? // tags séparés par virgules
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exercicesProgramme ExerciceProgramme[]
  templateItems      ExerciceTemplateItem[]
}

// ========== TEMPLATES D'EXERCICES ==========
model ExerciceTemplate {
  id          Int      @id @default(autoincrement())
  nom         String   @db.VarChar(255)
  description String?  @db.Text
  isPublic    Boolean  @default(false)
  kineId      Int
  kine        Kine     @relation(fields: [kineId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ExerciceTemplateItem[]

  @@index([kineId])
  @@index([isPublic])
  @@map("exercice_templates")
}

model ExerciceTemplateItem {
  id               Int              @id @default(autoincrement())
  templateId       Int
  template         ExerciceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exerciceModeleId Int
  exerciceModele   ExerciceModele   @relation(fields: [exerciceModeleId], references: [id])
  ordre            Int // Préserver l'ordre des exercices
  series           Int              @default(3)
  repetitions      Int              @default(10)
  tempsRepos       Int              @default(30) // en secondes
  tempsTravail     Int?             @default(0) // temps de travail en secondes (optionnel)
  instructions     String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([templateId])
  @@index([exerciceModeleId])
  @@map("exercice_template_items")
}

// ===========================================

model Programme {
  id          Int       @id @default(autoincrement())
  titre       String
  description String
  duree       Int // en jours
  dateDebut   DateTime  @default(now())
  dateFin     DateTime
  isArchived  Boolean   @default(false)
  archivedAt  DateTime? // Date d'archivage (pour suppression après 6 mois)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ========== SOFT DELETE ==========
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  // ================================

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id])

  exercices          ExerciceProgramme[]
  chatSessions       ChatSession[]
  sessionValidations SessionValidation[]
  notifications      Notification[]
}

model ExerciceProgramme {
  id               Int            @id @default(autoincrement())
  programme        Programme      @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  programmeId      Int
  exerciceModele   ExerciceModele @relation(fields: [exerciceModeleId], references: [id])
  exerciceModeleId Int

  series       Int
  repetitions  Int
  pause        Int // en secondes
  tempsTravail Int?   @default(0) // temps de travail en secondes (optionnel)
  consigne     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id        Int      @id @default(autoincrement())
  message   String // Le contenu du message
  role      ChatRole // Qui a envoyé le message
  createdAt DateTime @default(now())

  // Relations avec le patient ET le programme
  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  programmeId Int
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)

  // Index pour optimiser les requêtes
  @@index([patientId, programmeId])
  @@index([programmeId])
  @@map("chat_sessions")
}

model SessionValidation {
  id          Int       @id @default(autoincrement())
  date        DateTime  @db.Date // Date de la séance (YYYY-MM-DD)
  isValidated Boolean   @default(false)
  validatedAt DateTime? // Moment exact de la validation

  // Métriques
  painLevel       Int? // Douleur de 0 à 10 (null si pas encore validé)
  difficultyLevel Int? // Difficulté de 0 à 10 (null si pas encore validé)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  programmeId Int
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)

  // Contraintes : Un patient ne peut valider qu'une fois par jour pour un programme donné
  @@unique([patientId, programmeId, date])
  // Index pour optimiser les requêtes
  @@index([date, programmeId]) // Pour récupérer l'adhérence par date/programme
  @@index([patientId, date]) // Pour récupérer l'historique d'un patient
  @@index([programmeId]) // Pour stats globales d'un programme
  @@map("session_validations")
}

// ========== NOUVELLES TABLES IA ==========

model ChatIaBasique {
  id        Int      @id @default(autoincrement())
  message   String // Question du kiné
  response  String // Réponse de l'IA
  createdAt DateTime @default(now())

  // Relation avec le kiné
  kineId Int
  kine   Kine @relation(fields: [kineId], references: [id], onDelete: Cascade)

  // Index pour optimiser les requêtes par kiné et date
  @@index([kineId, createdAt])
  @@map("chat_ia_basique")
}

model ChatIaBiblio {
  id        Int      @id @default(autoincrement())
  message   String // Question du kiné
  response  String // Réponse de l'IA
  createdAt DateTime @default(now())

  // Relation avec le kiné
  kineId Int
  kine   Kine @relation(fields: [kineId], references: [id], onDelete: Cascade)

  // Index pour optimiser les requêtes par kiné et date
  @@index([kineId, createdAt])
  @@map("chat_ia_biblio")
}

model ChatIaClinique {
  id        Int      @id @default(autoincrement())
  message   String // Question du kiné
  response  String // Réponse de l'IA
  createdAt DateTime @default(now())

  // Relation avec le kiné
  kineId Int
  kine   Kine @relation(fields: [kineId], references: [id], onDelete: Cascade)

  // Index pour optimiser les requêtes par kiné et date
  @@index([kineId, createdAt])
  @@map("chat_ia_clinique")
}

model ChatIaAdministrative {
  id        Int      @id @default(autoincrement())
  message   String // Question du kiné
  response  String // Réponse de l'IA
  createdAt DateTime @default(now())

  // Relation avec le kiné
  kineId Int
  kine   Kine @relation(fields: [kineId], references: [id], onDelete: Cascade)

  // Index pour optimiser les requêtes par kiné et date
  @@index([kineId, createdAt])
  @@map("chat_ia_administrative")
}

// ==========================================

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType // Type de notification
  title     String // Titre court
  message   String // Message descriptif
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Relation obligatoire avec le kiné
  kineId Int
  kine   Kine @relation(fields: [kineId], references: [id], onDelete: Cascade)

  // Relations optionnelles pour le contexte
  patientId Int?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)

  programmeId Int?
  programme   Programme? @relation(fields: [programmeId], references: [id], onDelete: Cascade)

  // Métadonnées JSON pour infos supplémentaires
  metadata Json? // Ex: { "painLevel": 8, "difficultyLevel": 7, "validationDate": "2025-01-15" }

  // Index pour optimiser les requêtes
  @@index([kineId, isRead]) // Pour récupérer les notifications d'un kiné par statut
  @@index([kineId, createdAt]) // Pour trier par date
  @@index([type]) // Pour filtrer par type
  @@map("notifications")
}

// ========== NOUVEAUX ENUMS STRIPE ==========
enum PlanType {
  FREE
  DECLIC // 9€/mois - 1 chatbot + IA conversationnel
  PRATIQUE // 19€/mois - 3 chatbots + IA conversationnel + biblio + clinique
  PIONNIER // 20€/mois - Plan Expert à prix réduit (limité à 100 places)
  EXPERT // 49€/mois - Chatbots illimités + tous les assistants

  @@map("plan_type")
}

enum SubscriptionStatus {
  ACTIVE // Abonnement actif
  CANCELED // Annulé (mais encore actif jusqu'à la fin de période)
  PAST_DUE // Impayé
  UNPAID // Non payé
  INCOMPLETE // Paiement incomplet
  INCOMPLETE_EXPIRED // Paiement incomplet expiré
  TRIALING // En période d'essai
  PAUSED // Suspendu

  @@map("subscription_status")
}

// ==========================================

model RgpdExport {
  id           Int       @id @default(autoincrement())
  kineId       Int
  kine         Kine      @relation(fields: [kineId], references: [id], onDelete: Cascade)
  exportToken  String    @unique
  generatedAt  DateTime  @default(now())
  downloadedAt DateTime?
  expiresAt    DateTime
  fileSize     Int? // Taille du fichier en bytes
  isValid      Boolean   @default(true)

  // Métadonnées pour audit
  ipAddress String?
  userAgent String?

  // Index pour optimiser les requêtes
  @@index([kineId, generatedAt])
  @@index([exportToken])
  @@index([expiresAt])
  @@map("rgpd_exports")
}

enum NotificationType {
  DAILY_VALIDATION // Patient valide une journée
  PROGRAM_COMPLETED // Programme terminé
  PAIN_ALERT // Niveau douleur élevé (≥7)
  PATIENT_REQUEST // Patient demande à contacter son kiné
  SUPPORT_REPLY // Réponse admin à un ticket support

  @@map("notification_type")
}

enum ChatRole {
  USER // Message du patient
  ASSISTANT // Réponse de l'IA
  SYSTEM // Messages système (bienvenue, etc.)

  @@map("chat_role")
}

// ========== TABLES IA ADMINISTRATIVE ==========

model AdminTemplate {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(255) // Titre du template
  category   String   @db.VarChar(100) // Catégorie
  subject    String?  @db.VarChar(255) // Objet email suggéré
  body       String   @db.Text // Contenu avec variables [...]
  tags       String[] @default([]) // Tags pour recherche
  usageCount Int      @default(0) // Compteur utilisation
  isPublic   Boolean  @default(false) // true = template système visible par tous
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relation kiné (null = template système/public)
  kineId Int?
  kine   Kine? @relation(fields: [kineId], references: [id], onDelete: Cascade)

  // Relations
  templatesSentHistory TemplateSentHistory[]

  // Index pour recherche optimisée
  @@index([category])
  @@index([tags])
  @@index([kineId])
  @@map("admin_templates")
}

model TemplateSentHistory {
  id Int @id @default(autoincrement())

  // Relations
  kineId Int
  kine   Kine @relation(fields: [kineId], references: [id], onDelete: Cascade)

  patientId Int?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  templateId Int?
  template   AdminTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Données de l'envoi
  templateTitle  String              @db.VarChar(255) // Titre template (copie pour historique)
  subject        String              @db.VarChar(255) // Objet email final
  body           String              @db.Text // Contenu final personnalisé
  recipientName  String              @default("Inconnu") @db.VarChar(255) // Nom du destinataire
  recipientEmail String?             @db.VarChar(255) // Email du destinataire
  patientEmail   String?             @db.VarChar(255) // Email patient (legacy)
  patientPhone   String?             @db.VarChar(20) // Téléphone patient (si WhatsApp)
  method         CommunicationMethod @default(EMAIL) // Méthode d'envoi

  sentAt DateTime @default(now())

  // Index pour historique
  @@index([kineId, sentAt])
  @@index([patientId])
  @@index([contactId])
  @@index([templateId])
  @@map("templates_sent_history")
}

model Contact {
  id        Int      @id @default(autoincrement())
  kineId    Int
  kine      Kine     @relation(fields: [kineId], references: [id], onDelete: Cascade)
  firstName String?  @db.VarChar(100)
  lastName  String?  @db.VarChar(100)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  type      String?  @db.VarChar(100) // Texte libre : "Médecin", "Mutuelle"...
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templatesSentHistory TemplateSentHistory[]

  @@index([kineId])
  @@map("contacts")
}

enum CommunicationMethod {
  EMAIL
  WHATSAPP

  @@map("communication_method")
}

// =============================================

// ========== SYSTÈME DE PARRAINAGE ==========

model Referral {
  id Int @id @default(autoincrement())

  // Parrain (celui qui parraine)
  referrerId Int
  referrer   Kine @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)

  // Filleul (celui qui est parrainé) - unique car on ne peut être parrainé qu'une fois
  refereeId Int  @unique
  referee   Kine @relation("RefereeReferral", fields: [refereeId], references: [id], onDelete: Cascade)

  // Détails du parrainage
  planSubscribed PlanType // Plan souscrit par le filleul
  creditAmount   Float // Montant du crédit en euros (prix du plan)

  // Statut du parrainage
  status ReferralStatus @default(PENDING)

  // Tracking des crédits appliqués
  referrerCredited Boolean   @default(false) // Parrain a reçu son crédit
  refereeCredited  Boolean   @default(false) // Filleul a reçu son crédit
  creditedAt       DateTime? // Date d'application des crédits

  // Métadonnées anti-fraude
  refereeEmail String // Email du filleul au moment du parrainage
  refereeIp    String? // IP du filleul (optionnel)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Index pour optimiser les requêtes
  @@index([referrerId])
  @@index([status])
  @@index([createdAt])
  @@map("referrals")
}

enum ReferralStatus {
  PENDING // En attente du 1er renouvellement du filleul
  COMPLETED // Crédits appliqués aux deux parties
  CANCELED // Filleul a annulé avant le renouvellement
  EXPIRED // Délai dépassé sans renouvellement
  FRAUD // Marqué comme fraude (auto-parrainage détecté)

  @@map("referral_status")
}

// ============================================

// ========== SYSTÈME DE SUPPORT ==========

model SupportTicket {
  id         Int          @id @default(autoincrement())
  subject    String       @db.VarChar(255)
  status     TicketStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  resolvedAt DateTime?

  kineId Int
  kine   Kine @relation(fields: [kineId], references: [id], onDelete: Cascade)

  messages TicketMessage[]

  @@index([kineId, status])
  @@index([status, createdAt])
  @@map("support_tickets")
}

model TicketMessage {
  id        Int      @id @default(autoincrement())
  body      String   @db.Text
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticketId Int
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

enum TicketStatus {
  OPEN
  RESOLVED

  @@map("ticket_status")
}

// =========================================

// ========== TRAÇABILITÉ LÉGALE ==========

model LegalAcceptance {
  id              Int      @id @default(autoincrement())
  kineId          Int
  kine            Kine     @relation(fields: [kineId], references: [id], onDelete: Cascade)
  documentType    String   @db.VarChar(50) // "CGU", "POLITIQUE_CONFIDENTIALITE", "DPA"
  documentVersion String   @db.VarChar(10) // "1.0", "2.0", "3.0"
  acceptedAt      DateTime @default(now())
  ipAddress       String? // IP au moment de l'acceptation (audit trail RGPD)

  @@index([kineId, documentType])
  @@map("legal_acceptances")
}

// =============================================

// ========== BILANS KINÉSITHÉRAPIQUES ==========

enum BilanType {
  INITIAL
  INTERMEDIAIRE
  FINAL
}

model BilanKine {
  id             Int       @id @default(autoincrement())
  motif          String?   @db.VarChar(500) // Motif de consultation
  rawNotes       String    @db.Text // Notes brutes du kiné
  bilanHtml      String    @db.Text // HTML structuré généré par l'IA
  type           BilanType @default(INITIAL)
  structuredData Json? // Mesures canoniques + custom saisies par le kiné
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Soft delete
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  // Relations
  kineId    Int
  kine      Kine    @relation(fields: [kineId], references: [id], onDelete: Cascade)
  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([kineId, createdAt])
  @@index([patientId, createdAt])
  @@map("bilans_kine")
}

// ==== Champs canoniques (gérés via /dashboard/admin) ====

enum CanonicalFieldType {
  NUMERIC // ex: EVA 7/10, flexion 40° → input number + unité
  BOOLEAN // ex: Lasègue positif/négatif → toggle 2 états
  TEXT // ex: observation libre → input text
  ENUM // ex: testing musculaire 0/5..5/5 → select avec options
}

model BilanCanonicalField {
  id        Int                @id @default(autoincrement())
  key       String             @unique @db.VarChar(80) // snake_case stable, jamais renommer
  label     String             @db.VarChar(200) // libellé affiché kiné
  type      CanonicalFieldType
  unit      String?            @db.VarChar(20) // /10, °, cm... (NUMERIC)
  rangeMin  Float? // (NUMERIC)
  rangeMax  Float? // (NUMERIC)
  options   Json? // (ENUM) ex: ["0/5","1/5","2/5","3/5","4/5","5/5"]
  category  String             @db.VarChar(80) // regroupement UI
  order     Int                @default(0) // ordre d'affichage dans la catégorie
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([isActive, category, order])
  @@map("bilan_canonical_fields")
}

// ==== Templates de bilan (publics gérés par admin, privés par kiné) ====
// Un template = liste ordonnée d'items à pré-remplir dans structuredData
// (pas de valeurs, uniquement la composition).
// items JSON : [{ kind: "canonical", key: "eva_repos" } | { kind: "custom", label: "Test de Neer" }]

model BilanTemplate {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(150)
  description String? @db.VarChar(500)
  category    String  @db.VarChar(80) // libre, ex: "Rachis lombaire"
  items       Json // Liste ordonnée d'items (canonical|custom)
  isPublic    Boolean @default(false)

  // Soft delete
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // null si template public (créé via /dashboard/admin)
  kineId Int?
  kine   Kine? @relation(fields: [kineId], references: [id], onDelete: Cascade)

  @@index([isPublic, isActive])
  @@index([kineId, isActive])
  @@map("bilan_templates")
}

// ==============================================

// ========== CONTRATS REMPLACEMENT / ASSISTANAT ==========

enum ContractType {
  REMPLACEMENT_LIBERAL
  ASSISTANAT_LIBERAL

  @@map("contract_type")
}

enum ContractRoleInitiateur {
  TITULAIRE // Kiné déjà installé qui cherche un remplaçant/assistant
  REMPLACANT_OU_ASSISTANT // Kiné qui vient remplacer/assister

  @@map("contract_role_initiateur")
}

enum ContractStatus {
  BROUILLON // En cours de rédaction
  SIGNE_INITIATEUR // Initiateur a signé, pas encore envoyé
  ENVOYE // Lien envoyé au destinataire
  COMPLETE // Les 2 parties ont signé
  ARCHIVE // Archivé manuellement

  @@map("contract_status")
}

enum ContractSignerRole {
  INITIATEUR
  DESTINATAIRE

  @@map("contract_signer_role")
}

enum ContractInviteChannel {
  EMAIL
  WHATSAPP
  BOTH

  @@map("contract_invite_channel")
}

enum SignerAccountType {
  EXISTING_KINE // Compte Kine existant matché par email
  NEW_KINE // Compte Kine créé via le flow magic link
  GUEST // Signature en invité, sans compte

  @@map("signer_account_type")
}

// Carnet d'adresses kinés (séparé des Contact médecin/mutuelle existants)
// Infos minimales : juste pour identifier / contacter. Les vraies données sensibles
// vivent sur le modèle Kine (pour les inscrits) ou dans Contract.data (snapshot invité).
model ContactKine {
  id        Int      @id @default(autoincrement())
  kineId    Int
  kine      Kine     @relation(fields: [kineId], references: [id], onDelete: Cascade)
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  email     String   @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]

  @@unique([kineId, email])
  @@index([kineId])
  @@map("contacts_kine")
}

model Contract {
  id Int @id @default(autoincrement())

  // Initiateur (toujours présent)
  kineInitiateurId Int
  kineInitiateur   Kine @relation("ContractInitiateur", fields: [kineInitiateurId], references: [id], onDelete: Cascade)

  // Type et rôle de l'initiateur dans le contrat
  type           ContractType
  roleInitiateur ContractRoleInitiateur

  // Destinataire — infos minimales saisies par l'initiateur (nom/prénom/email/tel)
  contactKineId      Int?
  contactKine        ContactKine? @relation(fields: [contactKineId], references: [id], onDelete: SetNull)
  kineDestinataireId Int? // Set si l'email matche un compte Kine existant (lien interne, A ne voit pas les données de B)
  kineDestinataire   Kine?        @relation("ContractDestinataire", fields: [kineDestinataireId], references: [id], onDelete: SetNull)

  destinataireFirstName String  @db.VarChar(100)
  destinataireLastName  String  @db.VarChar(100)
  destinataireEmail     String  @db.VarChar(255)
  destinatairePhone     String? @db.VarChar(20)

  // Snapshot complet des données du contrat au moment de la complétion
  // Contient : état civil 2 kinés + infos spécifiques contrat (dates, lieu, %, conditions, etc.)
  data Json

  status ContractStatus @default(BROUILLON)

  // PDF final scellé après signature des 2 parties
  pdfFinalUrl         String? // Path GCS interne (ex: "contracts/42/contrat-final.pdf")
  pdfFinalHash        String? // SHA256 hex du PDF généré (intégrité)
  pdfFinalGeneratedAt DateTime?

  // Magic link pour l'accès destinataire — on stocke uniquement le HASH du JWT (jamais le brut)
  accessTokenHash      String?                @unique // SHA256(JWT)
  accessTokenChannel   ContractInviteChannel? // Canal d'envoi choisi par l'initiateur
  accessTokenSentAt    DateTime? // Quand l'envoi a été déclenché
  accessTokenExpiresAt DateTime?
  accessTokenUsedAt    DateTime? // Set à la signature finale (one-shot)
  accessTokenRevokedAt DateTime? // Révocation par l'initiateur (avant signature uniquement)

  // Audit log : [{ at, action, by, ip, ua, meta }]
  auditLog Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime? // Horodatage 2e signature

  // Déclaration au Conseil départemental de l'Ordre (obligation déontologique).
  // L'envoi ne se fait qu'après status=COMPLETE et est tracé pour audit + UI (badge "envoyé").
  ordreSentAt         DateTime?
  ordreRecipientEmail String?   @db.VarChar(255)
  ordreMessageId      String?

  signatures ContractSignature[]

  @@index([kineInitiateurId, createdAt])
  @@index([kineDestinataireId, createdAt])
  @@index([status])
  @@map("contracts")
}

model ContractSignature {
  id         Int      @id @default(autoincrement())
  contractId Int
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  signerRole      ContractSignerRole
  signerKineId    Int? // null si invité (sans compte)
  signerKine      Kine?              @relation(fields: [signerKineId], references: [id], onDelete: SetNull)
  signerEmail     String             @db.VarChar(255)
  signerFirstName String             @db.VarChar(100)
  signerLastName  String             @db.VarChar(100)
  signatureText   String             @db.VarChar(255) // "Prénom Nom" rendu en cursive dans le PDF
  mention         String?            @db.VarChar(255) // "Lu et approuvé" — preuve de consentement éclairé
  accountType     SignerAccountType? // Comment le signataire a accédé (compte existant, nouveau, ou invité)
  guestData       Json? // Si accountType=GUEST : snapshot des champs Kine étendus saisis pour le contrat

  // Audit trail
  ip        String?
  userAgent String?  @db.Text
  signedAt  DateTime @default(now())

  @@index([contractId, signerRole])
  @@map("contract_signatures")
}

